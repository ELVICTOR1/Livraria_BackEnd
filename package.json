{
  "name": "livraria",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --watch --env-file=.env src/index.js",
    "executar": "nodemon src/index.js",
    "generate_migration": "npx typeorm -d ./src/database/data-source.js migration:generate ./src/database/migrations/db --outputJs",
    "run_migrations": "npx typeorm -d ./src/database/data-source.js migration:run"
  },
  "license": "MIT",
  "dependencies": {
    "cloudinary": "^2.6.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "mysql2": "^3.14.0",
    "nodemailer": "^7.0.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.21"
  },
  "packageManager": "pnpm@11.1.2"
}
